# Copy to .env for local dev. On Vercel, set the same keys in Project → Settings → Environment Variables.
#
# Backend uses servlet context /api → base URL MUST include /api (not the bare Railway host).
REACT_APP_API_URL=https://aim-web-backend-product.up.railway.app/api
REACT_APP_CLOUD_NAME=dedurnabu
REACT_APP_UPLOAD_PRESET=aimagency_preset
